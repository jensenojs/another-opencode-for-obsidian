{
  "name": "another-opencode-for-obsidian",
  "version": "0.3.2",
  "description": "Another OpenCode integration for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "typecheck": "bun run tsc -p tsconfig.check.json -noEmit -skipLibCheck",
    "build": "bun run typecheck && bun run esbuild.config.mjs production",
    "test": "bun test",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"*.{json,md,mjs,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"*.{json,md,mjs,css}\"",
    "check": "bun run format:check && bun run lint && bun run build && bun test",
    "harness": "bun run scripts/harness.ts",
    "dev:install": "bun run scripts/harness.ts install",
    "dev:status": "bun run scripts/harness.ts status",
    "dev:logs": "bun run scripts/harness.ts logs",
    "dev:doctor": "bun run scripts/harness.ts doctor",
    "dev:bridge": "bun run scripts/harness.ts bridge",
    "dev:theme": "bun run scripts/harness.ts theme",
    "dev:theme:fixture": "bun run scripts/harness.ts theme --fixture",
    "dev:reload": "bun run scripts/harness.ts reload",
    "version": "bun run scripts/sync-manifest-version.ts && git add manifest.json",
    "version:patch": "bun pm version patch && git push --follow-tags",
    "version:minor": "bun pm version minor && git push --follow-tags",
    "version:major": "bun pm version major && git push --follow-tags"
  },
  "keywords": [
    "obsidian",
    "opencode",
    "ai",
    "assistant"
  ],
  "author": "mat",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.5",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "obsidian": "^1.13.1",
    "prettier": "^3.8.4",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.0"
  }
}
